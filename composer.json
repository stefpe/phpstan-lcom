{
    "name": "stefpe/phpstan-lcom",
    "description": "PHPStan rule to calculate LCOM4 (Lack of Cohesion of Methods) and report classes with low cohesion.",
    "type": "phpstan-extension",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "phpstan/phpstan": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "D435345\\PHPStanLcom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "D435345\\PHPStanLcom\\Tests\\": "tests/"
        }
    },
    "extra": {
        "phpstan": {
            "includes": [
                "conf/extension.neon"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --configuration phpstan.neon"
    }
}
